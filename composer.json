{
    "name": "mshk/core",
    "description": "The mshk Framework",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "illuminate/cache": "^10.0",
        "illuminate/container": "^10.0",
        "illuminate/database": "^10.0",
        "illuminate/bus": "^10.0",
        "illuminate/events": "^10.0",
        "illuminate/config": "^10.0",
        "illuminate/view": "^10.0",
        "illuminate/session": "^10.0",
        "illuminate/filesystem": "^10.0",
        "illuminate/validation": "^10.0",
        "illuminate/encryption": "^10.0",
        "illuminate/hashing": "^10.0",
        "illuminate/redis": "^10.0",
        "illuminate/notifications": "^10.0",
        "illuminate/queue": "^10.0",
        "illuminate/http": "^10.0",
        "intervention/image": "^3.0",
        "monolog/monolog": "^3.0",
        "laminas/laminas-stratigility": "^3.14",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "laminas/laminas-diactoros": "^3.8",
        "nikic/fast-route": "^1.3.0",
        "franzl/whoops-middleware": "^2.0.0",
        "neomerx/json-api": "^4.0",
        "dflydev/fig-cookies": "^3.2.0",
        "guzzlehttp/guzzle": "^7.0",
        "qcloud/cos-sdk-v5": "^2.0",
        "tencentcloud/tencentcloud-sdk-php": "^3.0.853",
        "league/flysystem": "^3.0",
        "symfony/console": "^6.4",
        "league/oauth2-server": "^8.0",
        "lcobucci/jwt": "^5.4",
        "overtrue/easy-sms": "^2.0",
        "dragonmantank/cron-expression": "^3.0",
        "ramsey/uuid": "^4.0",
        "phpoffice/phpspreadsheet": "^2.0"
    },
    "autoload": {
        "files": [
            "src/Foundation/helpers.php"
        ],
        "psr-4": {
            "mshk\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.1"
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
