{
    "name": "mshk/core",
    "description": "Discuz! Q Framework - 基于 Laravel Illuminate 组件的论坛系统框架",
    "type": "library",
    "keywords": ["discuz", "forum", "framework", "laravel", "illuminate"],
    "license": "proprietary",
    "authors": [
        {
            "name": "Discuz! Q Team",
            "email": "dev@discuz.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "illuminate/cache": "^11.0",
        "illuminate/container": "^11.0",
        "illuminate/database": "^11.0",
        "illuminate/bus": "^11.0",
        "illuminate/events": "^11.0",
        "illuminate/config": "^11.0",
        "illuminate/view": "^11.0",
        "illuminate/session": "^11.0",
        "illuminate/filesystem": "^11.0",
        "illuminate/validation": "^11.0",
        "illuminate/encryption": "^11.0",
        "illuminate/hashing": "^11.0",
        "illuminate/redis": "^11.0",
        "illuminate/notifications": "^11.0",
        "illuminate/queue": "^11.0",
        "illuminate/http": "^11.0",
        "intervention/image": "^2.5",
        "monolog/monolog": "^3.0",
        "laminas/laminas-stratigility": "^3.5",
        "laminas/laminas-httphandlerrunner": "^1.3",
        "laminas/laminas-diactoros": "^2.9",
        "nikic/fast-route": "^1.3.0",
        "tobscure/json-api": "^0.4.1",
        "dflydev/fig-cookies": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/guzzle-services": "^1.1",
        "qcloud/cos-sdk-v5": "^2.0",
        "tencentcloud/tencentcloud-sdk-php": "^3.0",
        "league/flysystem": "^3.0",
        "symfony/console": "^7.0",
        "league/oauth2-server": "^8.3",
        "lcobucci/jwt": "^5.0",
        "overtrue/easy-sms": "^1.1",
        "dragonmantank/cron-expression": "^2.3",
        "ramsey/uuid": "^4.7",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "autoload": {
        "files": [
            "src/Foundation/helpers.php"
        ],
        "psr-4": {
            "Discuz\\": "src/"
        }
    },
     "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "process-timeout": 300,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
